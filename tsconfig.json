{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "incremental": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/design-system/*": ["./src/components/design-system/*"],
      "@/helpers/*": ["./src/components/helpers/*"],
      "@/widgets/*": ["./src/components/widgets/*"],
      "@/pages/*": ["./src/components/pages/*"],
      "@/lambda/*": ["src/lambda-functions/*"],
      "@/keyframes/*": ["./src/keyframes/*"],
      "@/utils/*": ["./src/utils/*"],
      "@/hooks/*": ["./src/hooks/*"],
      "@/constants/*": ["./src/constants/*"],
      "@/contexts/*": ["./src/contexts/*"],
      "@/icons/*": ["./src/icons/*.svg"],
      "@/schemas/*": ["src/lambdas/schemas/*"]
    }
  },
  "ts-node": {
    "esm": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "src/lambda-functions/loadDummyData.ts",
    "src/components/helpers/Box/index.js",
    "src/components/helpers/Notch/index.tsx"
  ],
  "exclude": ["node_modules"]
}
